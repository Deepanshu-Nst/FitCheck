# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=*

# ─── Mock Services ─────────────────────────────────────────────────────────────
# Set to true to run fully without Supabase (local JSON DB + local file storage)
# Set to false when you have a Supabase project ready
USE_MOCK_SERVICES=true

# ─── API Base URL (used for local image URLs in mock mode) ─────────────────────
API_BASE_URL=http://localhost:3000

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=fitcheck-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ─── Supabase (only needed when USE_MOCK_SERVICES=false) ──────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=outfit-images

# ─── Groq AI ───────────────────────────────────────────────────────────────────
# Get a free API key at: https://console.groq.com
# If missing, app runs with realistic pre-built mock responses — works great for dev
GROQ_API_KEY=gsk_your_groq_api_key_here
