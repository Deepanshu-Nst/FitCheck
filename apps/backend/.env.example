# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=*

# ─── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=fitcheck-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────────
# Get your connection string from: https://console.neon.tech
# Project → Connection Details → Connection string
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-1.aws.neon.tech/fitcheck?sslmode=require

# ─── Cloudinary ──────────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Groq AI ─────────────────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com
# If missing, app runs with realistic mock AI responses
GROQ_API_KEY=gsk_your_key_here
