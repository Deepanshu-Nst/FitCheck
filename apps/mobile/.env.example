# ─── API ───────────────────────────────────────────────────────────────────────
# Change to your local IP when testing on a physical device
# e.g., http://192.168.1.100:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Supabase (Anon key — safe to expose to client) ───────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Google OAuth (for Google Sign-In via expo-auth-session) ──────────────────
# Get from: https://console.cloud.google.com → OAuth 2.0 Client IDs
# Create an "iOS" client ID and a "Web" client ID
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com
